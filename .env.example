# Единый шаблон переменных окружения Coffer (локальная разработка).
# Не коммить `.env` с реальными секретами.
#
# Разнеси значения по файлам:
#   apps/client/.env   — блок «Client»
#   apps/server/.env   — блок «Server» (Nest, Prisma, БД)

# ========== Client (Vite) → apps/client/.env ==========
VITE_APP_NAME=Coffer
# Локально не задавайте — запросы идут на /api (Vite proxy → :3000).
# Production (Vercel): URL бэкенда без завершающего слэша.
# VITE_API_URL=https://your-api.example.com

# ========== Server (Nest) → apps/server/.env ==========
# Локальный Nest — Transaction pooler (как в Supabase URI, порт 6543):
# Supabase → Database → Connection string → URI → Transaction mode
# Регион aws-0 / aws-1 должен совпадать с Dashboard (иначе «Tenant or user not found»).
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
#
# Direct db.* — только если хост пингуется из вашей сети (часто нужен IPv4 add-on):
# DATABASE_URL_DIRECT=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
#
# Лимит соединений pg Pool в dev (по умолчанию 2).
# DATABASE_POOL_MAX=2
DATABASE_PASS=<PASSWORD>
# Локально при P1011 «self-signed certificate in certificate chain» оставьте false (по умолчанию в dev).
# В production: true или уберите переменную и задайте NODE_ENV=production.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
PORT=3000
