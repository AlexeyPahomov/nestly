# Единый шаблон переменных окружения Nestly (локальная разработка).
# Не коммить `.env` с реальными секретами.
#
# Разнеси значения по файлам:
#   apps/client/.env   — блок «Client»
#   apps/server/.env   — блок «Server» (Nest, Prisma, БД)

# ========== Client (Vite) → apps/client/.env ==========
VITE_APP_NAME=Nestly

# ========== Server (Nest) → apps/server/.env ==========
# Формат как у Supabase pooler (подставь свои PROJECT_REF и пароль).
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_PASS=<PASSWORD>
PORT=3000
