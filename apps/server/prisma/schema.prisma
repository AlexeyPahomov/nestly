generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Income {
  id            String   @id @default(uuid())
  user_id       String
  amount        Decimal
  source        String?
  period_month  DateTime
  created_at    DateTime @default(now())

  allocations   Allocation[]
}

model Category {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  type       String
  icon       String   @default("shopping-cart")
  created_at DateTime @default(now())

  allocations Allocation[]
  expenses    Expense[]
}

model Allocation {
  id          String   @id @default(uuid())
  user_id     String
  income_id   String
  income      Income @relation(fields: [income_id], references: [id])
  category_id String
  category    Category @relation(fields: [category_id], references: [id])
  amount      Decimal
  created_at  DateTime @default(now())
}

model Expense {
  id          String   @id @default(uuid())
  user_id     String
  category_id String
  category    Category @relation(fields: [category_id], references: [id])
  amount      Decimal
  description String?
  date        DateTime
  created_at  DateTime @default(now())
}
